# For local dev, leave this unset — vite.config.ts proxies /api to
# http://localhost:8000 automatically.
#
# For production (e.g. deployed to Vercel), set this to your deployed
# backend's URL and update src/lib/api/client.ts to use it as baseURL
# instead of the relative "/api/v1" path.
VITE_API_BASE_URL=https://your-backend.onrender.com/api/v1
