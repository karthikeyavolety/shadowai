# Copy this file to .env and fill in real values before running.

APP_NAME=ShadowAI
ENV=development
# development: uses in-memory mongomock automatically if MONGO_URI is blank
# production: set MONGO_URI to your real MongoDB Atlas connection string

SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Leave blank to use the in-memory demo database (no setup required).
# For production, paste your MongoDB Atlas connection string here:
MONGO_URI=
MONGO_DB_NAME=shadowai

# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

CORS_ORIGINS=["http://localhost:5173"]

MAX_UPLOAD_SIZE_MB=5
